{
    "name": "Modify-LinuxVMPatchOrchestration",
    "type": "Microsoft.Authorization/policyDefinitions",
    "properties": {
        "policyType": "Custom",
        "mode": "All",
        "displayName": "Configure Linux virtual machines to use the 'Image default' patch orchestration option",
        "description": "This policy remediates existing Linux virtual machines by setting the patch orchestration option to 'Image default' (patchMode = ImageDefault). Use a remediation task to bring already-deployed virtual machines into compliance.",
        "metadata": {
            "version": "1.0.0",
            "category": "Compute"
        },
        "parameters": {
            "effect": {
                "type": "String",
                "metadata": {
                    "displayName": "Effect",
                    "description": "Enable or disable the execution of the policy."
                },
                "allowedValues": [
                    "Modify",
                    "Disabled"
                ],
                "defaultValue": "Modify"
            }
        },
        "policyRule": {
            "if": {
                "allOf": [
                    {
                        "field": "type",
                        "equals": "Microsoft.Compute/virtualMachines"
                    },
                    {
                        "field": "Microsoft.Compute/virtualMachines/storageProfile.osDisk.osType",
                        "equals": "Linux"
                    },
                    {
                        "field": "Microsoft.Compute/virtualMachines/osProfile.linuxConfiguration.patchSettings.patchMode",
                        "notEquals": "ImageDefault"
                    }
                ]
            },
            "then": {
                "effect": "[parameters('effect')]",
                "details": {
                    "roleDefinitionIds": [
                        "/providers/Microsoft.Authorization/roleDefinitions/9980e02c-c2be-4d73-94e8-173b1dc7cf3c"
                    ],
                    "conflictEffect": "audit",
                    "operations": [
                        {
                            "operation": "addOrReplace",
                            "field": "Microsoft.Compute/virtualMachines/osProfile.linuxConfiguration.patchSettings.patchMode",
                            "value": "ImageDefault"
                        }
                    ]
                }
            }
        }
    }
}
